{
  "expo": {
    "name": "Misu",
    "slug": "misu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icona_app.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "presamisure",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valen.presamisure"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icona_app.jpeg",
        "backgroundColor": "#0c2d75"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.valen.presamisure"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser"
    ]
  }
}
