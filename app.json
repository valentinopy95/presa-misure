{
  "expo": {
    "name": "Misu",
    "slug": "misu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icona_app.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "presamisure",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valen.presamisure"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icona_app.jpeg",
        "backgroundColor": "#0c2d75"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.valen.presamisure",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Misu usa la fotocamera per scattare foto durante il rilievo.",
          "photosPermission": "Misu accede alle foto per allegare immagini al rilievo."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Misu usa il microfono per registrare note vocali durante il rilievo."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ffb78a00-3421-4e07-a35b-0796c796c4d7"
      }
    },
    "owner": "valentinopy"
  }
}
