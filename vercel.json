{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "routes": [
    { "src": "/privacy", "dest": "/public/privacy.html" },
    { "src": "/terms", "dest": "/public/terms.html" },
    { "src": "/app(.*)", "dest": "/dist/$1" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
